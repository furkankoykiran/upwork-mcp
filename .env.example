# Upwork API Credentials
# Get these from: https://www.upwork.com/developer/keys/apply
UPWORK_CLIENT_ID=your_client_id_here
UPWORK_CLIENT_SECRET=your_client_secret_here

# OAuth Configuration
UPWORK_REDIRECT_URL=http://localhost:3000/callback
UPWORK_OAUTH_URL=https://www.upwork.com/ab/account-security/oauth2/authorize
UPWORK_TOKEN_URL=https://www.upwork.com/api/v3/oauth2/token

# GraphQL API Endpoint
UPWORK_API_URL=https://api.upwork.com/graphql

# Rate Limiting (requests per interval)
RATE_LIMIT_PER_SECOND=10
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_PER_DAY=40000
